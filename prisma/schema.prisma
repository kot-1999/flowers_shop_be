generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["strictUndefinedChecks"]
  adapter         = "postgresql"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName       String   @db.Text
  lastName        String   @db.Text
  firstNameSlug   String?  @db.Text
  lastNameSlug    String?  @db.Text
  email           String   @db.Text
  emailVerified   Boolean  @default(false) @db.Boolean
  password        String?  @db.Text
  role            UserRole @default(NotRegistered)
  googleProfileID String?
  phone           String?  @db.Text
  avatar          String?  @db.Text

  basketItems BasketItem[]
  orders      Order[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  addresses Address[]

  @@index([deletedAt])
  @@index([email])
  @@map("users")
}

model Address {
  id        String  @id @default(uuid()) @db.Uuid
  apartment String? @db.Text
  building  String  @db.Text
  street    String  @db.Text
  city      String  @db.Text
  postcode  String  @db.Text
  country   Country
  isDefault Boolean @db.Boolean

  userID String? @db.Uuid
  user   User?   @relation(fields: [userID], references: [id])
  orders Order[]

  // Metadata
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("addresses")
}

model Translation {
  id String @id @default(uuid()) @db.Uuid

  en     String  @db.Text
  enSlug String? @db.Text

  ua     String  @db.Text
  uaSlug String? @db.Text

  de     String  @db.Text
  deSlug String? @db.Text

  sk     String  @db.Text
  skSlug String? @db.Text

  selectionistNames Selectionist[] @relation("SelectionistName")

  categoryNames        Category[] @relation("CategoryName")
  categoryDescriptions Category[] @relation("CategoryDescription")

  tagNames      Tag[]      @relation("TagName")
  itemTypeNames ItemType[] @relation("ItemTypeName")

  goodNames        Good[] @relation("GoodName")
  goodDescriptions Good[] @relation("GoodDescription")

  @@map("translations")
}

model Category {
  id String @id @default(uuid()) @db.Uuid

  nameTID String      @db.Uuid
  name    Translation @relation("CategoryName", fields: [nameTID], references: [id])

  descriptionTID String      @db.Uuid
  description    Translation @relation("CategoryDescription", fields: [descriptionTID], references: [id])

  coverImage String?

  goods Good[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("categories")
}

model Good {
  id String @id @default(uuid()) @db.Uuid

  state  GoodState
  photos String[]

  nameTID String      @db.Uuid
  name    Translation @relation("GoodName", fields: [nameTID], references: [id])

  descriptionTID String      @db.Uuid
  description    Translation @relation("GoodDescription", fields: [descriptionTID], references: [id])

  categoryID String   @db.Uuid
  category   Category @relation(fields: [categoryID], references: [id])

  selectionistID String       @db.Uuid
  selectionist   Selectionist @relation(fields: [selectionistID], references: [id])

  pricings    GoodPricing[]
  tags        GoodTag[]
  basketItems BasketItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([state])
  @@index([categoryID])
  @@index([createdAt])
  @@index([selectionistID])
  @@index([deletedAt])
  @@index([categoryID, state])
  @@map("goods")
}

model Pricing {
  id String @id @default(uuid()) @db.Uuid

  price Decimal @db.Decimal(10, 2)

  quantity Int @db.Integer

  itemTypeID String   @db.Uuid
  itemType   ItemType @relation(fields: [itemTypeID], references: [id])

  goods       GoodPricing[]
  basketItems BasketItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([itemTypeID])
  @@map("pricings")
}

model GoodPricing {
  pricingID String @db.Uuid
  goodID    String @db.Uuid

  pricing Pricing @relation(fields: [pricingID], references: [id], onDelete: Cascade)
  good    Good    @relation(fields: [goodID], references: [id], onDelete: Cascade)

  @@id([goodID, pricingID])
  @@map("good_pricings")
}

model GoodTag {
  goodID String @db.Uuid
  tagID  String @db.Uuid

  good Good @relation(fields: [goodID], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagID], references: [id], onDelete: Cascade)

  @@id([goodID, tagID])
  @@map("good_tags")
}

model ItemType {
  id String @id @default(uuid()) @db.Uuid

  weight Decimal @db.Decimal(10, 2)

  nameTID String      @db.Uuid
  name    Translation @relation("ItemTypeName", fields: [nameTID], references: [id])

  pricing Pricing[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("item_types")
}

model Selectionist {
  id String @id @default(uuid()) @db.Uuid

  country String?

  nameTID String      @db.Uuid
  name    Translation @relation("SelectionistName", fields: [nameTID], references: [id])

  goods Good[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("selectionists")
}

model BasketItem {
  id String @id @default(uuid()) @db.Uuid

  quantity Int

  goodID    String @db.Uuid
  userID    String @db.Uuid
  pricingID String @db.Uuid

  good    Good    @relation(fields: [goodID], references: [id])
  user    User    @relation(fields: [userID], references: [id])
  pricing Pricing @relation(fields: [pricingID], references: [id])

  createdAt DateTime @default(now())

  @@unique([goodID, userID, pricingID])
  @@index([userID])
  @@index([goodID])
  @@index([pricingID])
  @@map("basket_items")
}

model Order {
  id String @id @default(uuid()) @db.Uuid

  transactionID  String     @unique
  sum            Decimal    @db.Decimal(12, 2)
  state          OrderState
  trackingUrl    String?
  trackingNumber String?

  userID String @db.Uuid
  user   User   @relation(fields: [userID], references: [id])

  addressID String  @db.Uuid
  address   Address @relation(fields: [addressID], references: [id])

  orderItems OrderItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  @@index([userID])
  @@index([state])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([state, expiresAt])
  @@map("orders")
}

model OrderItem {
  id String @id @default(uuid()) @db.Uuid

  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  snapshot Json

  orderID String @db.Uuid
  order   Order  @relation(fields: [orderID], references: [id])

  createdAt DateTime @default(now())

  @@index([orderID])
  @@map("order_items")
}

model Tag {
  id String @id @default(uuid()) @db.Uuid

  nameTID String      @db.Uuid
  name    Translation @relation("TagName", fields: [nameTID], references: [id])

  goods GoodTag[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("tags")
}

enum UserRole {
  Admin
  User
  NotRegistered
}

enum GoodState {
  Available
  NoShow
  Awaiting
  Deleted
}

enum OrderState {
  Pending
  Paid
  Processing
  Shipped
  Delivered
  Cancelled
  Refunded
}

